# Copy to .env for local overrides. Dev defaults work without any real cloud account.

# Control plane (backend)
ConnectionStrings__Default=Host=localhost;Port=5432;Database=r8er;Username=r8er;Password=dev
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_PROJECT_ID=demo-r8er

# Frontend (Vite exposes only VITE_-prefixed vars)
VITE_API_URL=http://localhost:5000
VITE_FIREBASE_AUTH_EMULATOR=http://localhost:9099
VITE_FIREBASE_PROJECT_ID=demo-r8er

# Agent
R8ER_CONTROL_PLANE_URL=ws://localhost:5000/signaling
R8ER_JELLYFIN_URL=http://localhost:8096

# Local TURN (compose --profile relay); dev toggle forces relay in the client
VITE_TURN_URL=turn:localhost:3478
VITE_TURN_USER=dev
VITE_TURN_PASS=dev

# Production-only (never set locally): Cloudflare TURN API token, real Firebase
# service account, R2 credentials — provisioned at deploy time, human-approved.
